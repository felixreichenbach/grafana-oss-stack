# -----------------------------
# Loki (logs)
# -----------------------------
# These three vars are consumed by both config.local.alloy and config.cloud.alloy.
ALLOY_CONFIG_FILE=config.cloud.alloy
LOKI_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push
LOKI_USERNAME=YOUR_GRAFANA_CLOUD_STACK_ID
LOKI_PASSWORD=YOUR_GRAFANA_CLOUD_API_KEY

# -----------------------------
# Mimir (metrics)
# -----------------------------
MIMIR_URL=https://prometheus-prod-XXX.grafana.net/api/prom/push
MIMIR_USERNAME=YOUR_GRAFANA_CLOUD_STACK_ID
MIMIR_PASSWORD=YOUR_GRAFANA_CLOUD_API_KEY

# -----------------------------
# Tempo (traces)
# -----------------------------
TEMPO_URL=https://tempo-prod-XXX.grafana.net:443
TEMPO_USERNAME=YOUR_GRAFANA_CLOUD_STACK_ID
TEMPO_PASSWORD=YOUR_GRAFANA_CLOUD_API_KEY

# -----------------------------
# Pyroscope (profiles)
# -----------------------------
PYROSCOPE_URL=https://profiles-prod-XXX.grafana.net
PYROSCOPE_USERNAME=YOUR_GRAFANA_CLOUD_STACK_ID
PYROSCOPE_PASSWORD=YOUR_GRAFANA_CLOUD_API_KEY

# -----------------------------
# OTLP gateway (optional unified ingest)
# -----------------------------
OTLP_ENDPOINT=https://otlp-gateway-prod-XXX.grafana.net/otlp
OTLP_USERNAME=YOUR_GRAFANA_CLOUD_STACK_ID
OTLP_PASSWORD=YOUR_GRAFANA_CLOUD_API_KEY

# Optional signal-specific OTLP endpoints (if you do not use OTLP_ENDPOINT):
OTLP_LOGS_ENDPOINT=https://otlp-gateway-prod-XXX.grafana.net/otlp/v1/logs
OTLP_METRICS_ENDPOINT=https://otlp-gateway-prod-XXX.grafana.net/otlp/v1/metrics
OTLP_TRACES_ENDPOINT=https://otlp-gateway-prod-XXX.grafana.net/otlp/v1/traces

# -----------------------------
# Grafana Fleet Management (optional)
# -----------------------------
# Only needed if you enable Alloy fleet/remote configuration.
FLEET_MANAGEMENT_URL=https://fleet-management-prod-XXX.grafana.net
FLEET_MANAGEMENT_USERNAME=YOUR_GRAFANA_CLOUD_STACK_ID
FLEET_MANAGEMENT_PASSWORD=YOUR_GRAFANA_CLOUD_API_KEY
